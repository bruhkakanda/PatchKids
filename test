--[[
    ╔══════════════════════════════════════╗
    ║         WHITELIST KEY SYSTEM         ║
    ║    Synapse X — Client Script Only    ║
    ╚══════════════════════════════════════╝

    • Fetches allowed usernames from your GitHub config
    • If the player is whitelisted and has no key → generates one and saves it forever
    • If the player already has a saved key → validates it instantly, no GitHub fetch needed
    • If not whitelisted → denies access
]]

-- ─────────────────────────────────────────
-- CONFIG
-- ─────────────────────────────────────────
local CONFIG_URL   = "https://raw.githubusercontent.com/bruhkakanda/PatchKids/refs/heads/main/config"
local SAVE_FOLDER  = "PatchKids"
local SAVE_FILE    = "PatchKids/%s.key"  -- %s = username

-- ─────────────────────────────────────────
-- Services
-- ─────────────────────────────────────────
local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player   = Players.LocalPlayer
local username = player.Name
local filePath = SAVE_FILE:format(username)

-- ─────────────────────────────────────────
-- File helpers
-- ─────────────────────────────────────────
local function ensureFolder()
    if not isfolder(SAVE_FOLDER) then
        makefolder(SAVE_FOLDER)
    end
end

local function hasSavedKey()
    return isfile(filePath)
end

local function loadSavedKey()
    if isfile(filePath) then
        return readfile(filePath)
    end
    return nil
end

local function generateKey()
    -- Unique key: username + random 16-char hex string
    local rand = syn.crypt.random(8)  -- 8 bytes = 16 hex chars
    local hex  = syn.crypt.base64.encode(rand):gsub("[^%w]", ""):sub(1, 16):upper()
    return ("PK-%s-%s"):format(username:upper(), hex)
end

local function saveKey(key)
    ensureFolder()
    writefile(filePath, key)
end

-- ─────────────────────────────────────────
-- GitHub config fetch
-- ─────────────────────────────────────────
local function fetchWhitelist()
    local ok, result = pcall(function()
        return game:HttpGet(CONFIG_URL)
    end)
    if not ok or not result then
        return nil, "Failed to fetch whitelist"
    end

    local fn, err = loadstring(result)
    if not fn then
        return nil, "Config parse error: " .. tostring(err)
    end

    local list = fn()
    if type(list) ~= "table" then
        return nil, "Config returned unexpected format"
    end

    return list, nil
end

local function isWhitelisted(list)
    for _, name in ipairs(list) do
        if name:lower() == username:lower() then
            return true
        end
    end
    return false
end

