-- ─────────────────────────────────────────
-- UI update helpers
-- ─────────────────────────────────────────
local function setStatus(icon, msg, iconColor, msgColor)
    statusIcon.Text       = icon
    statusIcon.TextColor3 = iconColor or MUTED
    statusText.Text       = msg
    statusText.TextColor3 = msgColor or MUTED
end

local function showKey(key)
    keyBox.Text    = key
    keyBox.Visible = true
    -- Resize card to fit
    tween(card, { Size = UDim2.new(0, 360, 0, 270) }, 0.25)
    tween(card, { Position = UDim2.new(0.5, -180, 0.5, -135) }, 0.25)
end

local function dismiss(delay)
    task.wait(delay or 2)
    tween(overlay, { BackgroundTransparency = 1 }, 0.3)
    tween(card,    { BackgroundTransparency = 1 }, 0.3)
    task.wait(0.35)
    gui:Destroy()
end

-- ─────────────────────────────────────────
-- MAIN PAYLOAD — put your script here
-- ─────────────────────────────────────────
local function runPayload(key)
    setStatus("✓", "Access granted — welcome, " .. username .. "!", SUCCESS, SUCCESS)
    if key then
        subtitle.Text = "Your permanent key (saved to files):"
        showKey(key)
        task.wait(3)
    else
        task.wait(1)
    end
    dismiss(0)

    -- ╔══════════════════════════════╗
    -- ║  YOUR MAIN SCRIPT HERE      ║
    -- ╚══════════════════════════════╝
    print("[PatchKids] Running for " .. username)
end

-- ─────────────────────────────────────────
-- STARTUP LOGIC
-- ─────────────────────────────────────────

-- Animate card in
card.BackgroundTransparency    = 1
overlay.BackgroundTransparency = 1
task.defer(function()
    tween(overlay, { BackgroundTransparency = 0.5 }, 0.3)
    tween(card,    { BackgroundTransparency = 0   }, 0.3)
end)

task.spawn(function()

    -- Step 1: Check for existing saved key first (fastest path)
    local saved = loadSavedKey()
    if saved then
        setStatus("🔑", "Found saved key, verifying...", WARN, MUTED)
        task.wait(0.5)

        -- Key file exists = they were previously whitelisted, let them straight in
        -- (key was generated by this script so it's trusted)
        runPayload(nil)
        return
    end

    -- Step 2: No saved key — fetch whitelist from GitHub
    setStatus("⏳", "Fetching whitelist from GitHub...", WARN, MUTED)

    local list, err = fetchWhitelist()
    if not list then
        setStatus("✗", "Error: " .. err, FAIL, FAIL)
        dismiss(3)
        return
    end

    -- Step 3: Check if player is whitelisted
    if not isWhitelisted(list) then
        setStatus("✗", username .. " is not whitelisted.", FAIL, FAIL)
        subtitle.Text = "Contact the script owner to get access."
        tween(cardStroke, { Color = FAIL }, 0.2)
        dismiss(4)
        return
    end

    -- Step 4: Whitelisted but no key yet — generate and save one
    setStatus("⚙", "Whitelisted! Generating your key...", ACCENT, MUTED)
    task.wait(0.6)

    local key = generateKey()
    local saveOk, saveErr = pcall(saveKey, key)

    if not saveOk then
        setStatus("✗", "Could not save key: " .. tostring(saveErr), FAIL, FAIL)
        dismiss(3)
        return
    end

    -- Step 5: Run
    runPayload(key)

end)
