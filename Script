G2L_MODULES[G2L["2a"]] = {
    Closure = function()
        local script = G2L["2a"]

        local module = {
            Icons = {
                Main      = { "rbxassetid://11894535915",    0.75 },
                Settings  = { "rbxassetid://7059346373",     0.9  },
                Universal = { "rbxassetid://102051406940109",0.75 },
                Premium   = { "rbxassetid://108595388656831",0.9  },
                Event     = { "rbxassetid://76784744831858", 0.9  },
                Home      = { "rbxassetid://104608276336944",0.75 }
            }
        }

        -- ── Changelog helpers ─────────────────────────────────
        local function newUnderline(text, toAdd)
            return text .. "<br/>" .. " •" .. " " .. toAdd
        end

        local function addTitle(text, toAdd)
            local suffix = (text == "") and "" or "<br/> <br/>"
            return text .. suffix .. "[" .. toAdd .. "]"
        end

        module.FixDashboard = function(data)
            local currentChange = ""
            local changelog     = dashboard.Changelog
            local Header        = data.Header
            local ver           = data.Version
            local Index         = data.Index

            changelog.Changelog.Text = ver

            for _, indexName in Index do
                local header = Header[indexName]
                if header then
                    currentChange = addTitle(currentChange, indexName)
                    for _, log in header do
                        currentChange = newUnderline(currentChange, log)
                    end
                end
            end

            changelog.Info.Text = currentChange
			local backgroundUI = changelog.BG

			-- wait for UI to update
			task.wait()

			local textBounds = changelog.Info.TextBounds

			-- now you can resize background
			backgroundUI.Size = UDim2.new(1, 0, 0.4, textBounds.Y)
        end

        -- ── New tab creator ───────────────────────────────────
        function module.New(TabName, val, icon)
            local newTab

            if TabName ~= "Home" then
                newTab            = GeneratedTemplates.TemplateTab:Clone()
                newTab.Label.Text = TabName
                newTab.Label.Visible = false
                newTab.Name       = TabName
                newTab.Parent     = script.Parent.Parent.NewTabs
            else
                newTab        = library.Dashboard()
                newTab.Name   = "Home"
                newTab.Parent = script.Parent.Parent.NewTabs
                dashboard     = newTab

				local changelog = newTab.Changelog
				local newBG = changelog:Clone()
				newBG.Name = "BG"
				newBG.Parent = changelog
				changelog.BackgroundTransparency = 1
				changelog.UIStroke.Enabled = false
				newBG.Size = UDim2.fromScale(1,1)
				newBG.Info:Destroy()
				newBG.Changelog:Destroy()
				newBG.ZIndex = -10
				
				newBG:AddTag("A")
				library.AddThemesToTemplate(newBG)

            end

            -- Tab button
            local tabButton             = GeneratedTemplates.TabButton:Clone()
            tabButton.Name              = TabName
            tabButton.Title.Text        = TabName
			tabButton.Title.TextXAlignment = Enum.TextXAlignment.Left
            tabButton.LayoutOrder       = val or 1
            tabButton.Visible           = true
            tabButton.Parent            = script.Parent.Parent.Tabs
            library.AddThemesToTemplate(tabButton)

            local iconData = module.Icons[TabName]
            if iconData then
                tabButton.ImageLabel.Image = iconData[1]
                tabButton.ImageLabel.Size  = UDim2.fromScale(tabButton.ImageLabel.Size.X.Scale, iconData[2])
            end

            if TabName == "Home" then
                tabButton.LayoutOrder = -10
            elseif TabName == "Premium" then
                tabButton.Title.TextColor3          = Color3.fromRGB(164, 157, 255)
                tabButton.ImageLabel.ImageColor3    = Color3.fromRGB(164, 157, 255)
            end

            -- End padding label
            if newTab:FindFirstChild("Label") then
                local endLabel                  = newTab.Label:Clone()
                endLabel.Text                   = ""
                endLabel.Size                   = UDim2.fromScale(1, 0.3)
                endLabel.LayoutOrder            = 1000
                endLabel.Visible                = true
                endLabel.Name                   = "End"
                endLabel.BackgroundTransparency = 1
                endLabel.Parent                 = newTab
            end

            -- Tab switching
            tabButton.ChangeTabs.Activated:Connect(function()
                for _, v in pairs(script.Parent.Parent.NewTabs:GetChildren()) do
                    v.Visible = false
                end
                script.Parent.Parent.NewTabs:FindFirstChild(TabName).Visible = true
            end)

            -- Hover effect
            local tabColor = tabButton.BackgroundColor3
            tabButton.ChangeTabs.MouseEnter:Connect(function()
                tabColor = tabButton.BackgroundColor3
                local h, s, v = Color3.toHSV(tabColor)
                local lightColor = Color3.fromHSV(h, s * 0.8, math.min(v + 0.2, 1))
                game.TweenService:Create(tabButton, TweenInfo.new(0.1), { BackgroundColor3 = lightColor }):Play()
            end)

            tabButton.ChangeTabs.MouseLeave:Connect(function()
                game.TweenService:Create(tabButton, TweenInfo.new(0.1), { BackgroundColor3 = tabColor }):Play()
            end)
        end

        return module
