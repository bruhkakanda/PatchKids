        local Players  = game:GetService("Players")
        local player   = Players.LocalPlayer

        local function getRoles()
            local roles = game.ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
            for name, data in roles do
                if data.Role == "Murderer" then
                    return game.Players:FindFirstChild(name)
                end
            end
            return nil
        end

        local function predictPosition(part, ping)
            return part.Position + part.Velocity * (ping * 10 * 0.405)
        end

        function module.Shoot()
            local target   = getRoles()
