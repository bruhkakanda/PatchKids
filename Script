					or input.UserInputType == Enum.UserInputType.Touch then
					beginDrag()
				end
			end)

			Slider.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					beginDrag()
					updateSlider(UserInputService:GetMouseLocation().X)
				end
