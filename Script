				end
				tweenScale(1)
			end

			local function scheduleHideInfo()
				if hideInfoThread then task.cancel(hideInfoThread) end
				hideInfoThread = task.delay(INFO_HIDE_DELAY, function()
					tweenScale(0)
					hideInfoThread = nil
				end)
			end

			local function updateSlider(inputX)
				local absPos = Slider.AbsolutePosition
				local absSize = Slider.AbsoluteSize

				local relX = math.clamp(inputX - absPos.X, 0, absSize.X)
				local alpha = relX / absSize.X

				currentValue = Min + alpha * (Max - Min)
				currentValue = math.clamp(currentValue, Min, Max)

				Moving.Position = UDim2.new(alpha, 0, 0.5, 0)
				Info.Text = string.format("%.2f", currentValue)

				if Callback then Callback(currentValue) end
			end

