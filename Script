-- ══════════════════════════════════════════════════════════════
local G2L_REQUIRE = require
local G2L_MODULES = {}

local function require(Module: ModuleScript)
    local state = G2L_MODULES[Module]
    if state then
        if not state.Required then
            state.Required = true
            state.Value    = state.Closure()
        end
        return state.Value
    end
    return G2L_REQUIRE(Module)
end

