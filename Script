G2L_MODULES[G2L["3a"]] = {
    Closure = function()
        local script = G2L["3a"]

        local module = {
            Settings = {
                CoinAutofarm = {
                    AutoReset  = false,
                    TPWhenDone = false,
                }
            }
        }

        local NewNotification = require(script.Parent.Parent.Parent.NewNotification)

        local TOGGLE         = false
        local noclip         = false
        local LOCKED_Y       = nil
        local canReset       = true
        local SPEED          = 20
        local NO_COIN_TIMEOUT = 5
        local lastCoinSeen   = os.clock()

        local RunService = game:GetService("RunService")
        local Players    = game:GetService("Players")

        local char     = Players.LocalPlayer.Character or Players.LocalPlayer.CharacterAdded:Wait()
        local humanoid = char:WaitForChild("Humanoid")

        -- ── Noclip ────────────────────────────────────────────
        local noclipConnection = nil

        local function startNoclip()
            if noclipConnection then return end
            noclipConnection = RunService.Stepped:Connect(function()
                local c = Players.LocalPlayer.Character
                if not c then return end
                for _, v in c:GetDescendants() do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)
        end

        local function stopNoclip()
            if noclipConnection then
                noclipConnection:Disconnect()
                noclipConnection = nil
            end
        end

        -- ── Toggle ────────────────────────────────────────────
        module.toggle = function(toggle)
            TOGGLE = toggle
            if toggle then
                noclip                = true
                workspace.Gravity     = 0
                humanoid.PlatformStand = true
                startNoclip()
            else
                noclip                = false
                workspace.Gravity     = 196.2
                humanoid.PlatformStand = false
                stopNoclip()
            end
        end

        -- ── Coin finder ───────────────────────────────────────
        local function getClosestCoin(root)
            local closestCoin = nil
            local closestDist = math.huge
            local CoinContainer = workspace:FindFirstChild("CoinContainer", true)

            if CoinContainer then
                for _, v in CoinContainer:GetChildren() do
                    local coin = v:FindFirstChild("CoinVisual")
                    if coin and coin:FindFirstChild("MainCoin") and coin.MainCoin.Transparency == 0 then
                        local dist = (coin.Position - root.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closestCoin = coin
                        end
                    end
                end
            end

            return closestCoin, closestDist
        end

        -- ── Lobby TP ──────────────────────────────────────────
        local function tpToLobby()
            local lobby = workspace:FindFirstChild("Lobby") or workspace:FindFirstChild("RegularLobby")
            if lobby then
                local spawns = lobby:FindFirstChild("Spawns")
                if spawns then
                    local rCF = spawns:GetChildren()[math.random(1, #spawns:GetChildren())].CFrame + Vector3.new(0, 2, 0)
                    game.Players.LocalPlayer.Character:PivotTo(rCF)
                end
            end
        end

        -- ── Movement loop ─────────────────────────────────────
        local moveConnection     = nil
        local currentCoinVisual  = nil
        local currentCoin        = nil

        local function stopMoving()
            if moveConnection then
                moveConnection:Disconnect()
                moveConnection = nil
            end
            currentCoinVisual = nil
            currentCoin       = nil
        end

        local function startMoving(root, coinVisual, coin)
            if moveConnection then return end
            currentCoinVisual = coinVisual
            currentCoin       = coin

            moveConnection = RunService.Heartbeat:Connect(function(dt)
                if not (currentCoinVisual and currentCoinVisual.Parent) then stopMoving() return end
                if currentCoinVisual:FindFirstChild("MainCoin") and currentCoinVisual.MainCoin.Transparency ~= 0 then stopMoving() return end
                if not TOGGLE then stopMoving() return end

                -- Pull nearby coins to player
                local CoinContainers = workspace:FindFirstChild("CoinContainer", true)
                if CoinContainers then
                    for _, coinAura in CoinContainers:GetChildren() do
                        local cv = coinAura:FindFirstChild("CoinVisual")
                        if cv and cv:FindFirstChild("MainCoin") and cv.MainCoin.Transparency == 0 then
                            if (root.Position - coinAura.Position).Magnitude < 5 then
                                coinAura.Position = root.Position
                            end
                        end
                    end
                end

                local currentPos = root.Position
                local targetPos  = Vector3.new(currentCoin.Position.X, LOCKED_Y, currentCoin.Position.Z)
                local direction  = targetPos - currentPos
                local dist       = direction.Magnitude

                if dist > 0.5 then
                    local step   = math.min(SPEED * dt, dist)
                    local newPos = currentPos + direction.Unit * step
                    root.CFrame  = CFrame.new(newPos) * CFrame.Angles(math.rad(90), 0, 0)
                else
                    stopMoving()
                end
            end)
        end

        -- ── Main loop ─────────────────────────────────────────
        local lastTick = 0

        module.Start = function()
            local settings = module.Settings.CoinAutofarm

            RunService.Heartbeat:Connect(function()
                if os.clock() - lastTick < 0.2 then return end
                lastTick = os.clock()

                if TOGGLE then
                    local c = Players.LocalPlayer.Character
                    if not (c and c.Parent and c:FindFirstChild("Humanoid")) then return end

                    local hum  = c:WaitForChild("Humanoid")
                    local root = c.PrimaryPart

                    local coinVisual = getClosestCoin(root)
                    local coin       = nil

                    if coinVisual and coinVisual.Parent and coinVisual:FindFirstChild("MainCoin") then
                        coin = coinVisual.Parent
                    end

                    if not (coinVisual and coinVisual.Parent) then
                        if os.clock() - lastCoinSeen < NO_COIN_TIMEOUT then return end

                        if canReset then
                            noclip                = false
                            hum.PlatformStand     = false
                            workspace.Gravity     = 196.2
                            if settings.AutoReset  then hum.Health = 0 end
                            if settings.TPWhenDone then tpToLobby() end
                            canReset = false
                            stopNoclip()
                            stopMoving()
                        end
                        return
                    end

                    canReset              = true
                    lastCoinSeen          = os.clock()
                    noclip                = true
                    hum.PlatformStand     = true
                    workspace.Gravity     = 0
                    startNoclip()

                    if not (coin and coin.Parent) then return end

                    if not LOCKED_Y then LOCKED_Y = root.Position.Y end

                    local targetY = coin.Position.Y - (coin.Size.Y / 2) - 2
                    if math.abs(targetY - LOCKED_Y) > 0.1 then LOCKED_Y = targetY end

                    root.Anchored = false
                    startMoving(root, coinVisual, coin)

                else
                    workspace.Gravity = 196.2
                    noclip            = false
                    stopNoclip()
                    stopMoving()

                    local c = Players.LocalPlayer.Character
                    if c and c:FindFirstChild("Humanoid") then
                        c.Humanoid.PlatformStand = false
                    end
                    LOCKED_Y = nil
                end
            end)
        end

        return module
    end
}

