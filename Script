            local backpackGun  = player.Backpack:FindFirstChild("Gun")
            if backpackGun then backpackGun.Parent = myChar end

            local gun = myChar:FindFirstChild("Gun")
            if gun then
                gun.Shoot:FireServer(hand.CFrame, CFrame.new(predictedPos))
            end
        end

        return module
    end
}

