-- Loading screen
task.spawn(function()
    local script = G2L["5f"]

    local function tw(text, t, w)
        for i = 1, #text do
            t.Text = string.sub(text, 1, i)
            task.wait(w)
        end
    end

    script.Parent.UIScale.Scale = 0

    local m    = require(script.Parent.Parent.mainframe.Loader.NewNotification)
    local c    = API.loading.topbar
    local list = c.List

    local freeKey = "FREE"
    local KEY     = "FREE"

    list.welcome.Text = ""
    task.wait(1)

    local function setFetch(icon, text, textColor)
        local colors = {
            White = Color3.fromRGB(255, 255, 255),
            Red   = Color3.fromRGB(255, 105, 97),
            Green = Color3.fromRGB(119, 221, 119),
        }
        list.Fetch.Icon.Text       = icon
        list.Fetch.Icon.TextColor3 = colors[textColor] or colors.White
        list.Fetch.txt.Text        = ""
        tw(text, list.Fetch.txt, 0.01)
    end

    wait(2)
    game.TweenService:Create(script.Parent.UIScale, TweenInfo.new(0.2), { Scale = 1 }):Play()

    if _G.key == "nil" then
        list.TextBox.Text = freeKey
    end

    local premiumUsers = loadstring(game:HttpGet("https://raw.githubusercontent.com/bruhkakanda/PatchKids/refs/heads/main/config"))()
    local isPremium    = table.find(premiumUsers, game.Players.LocalPlayer.Name) ~= nil

    if isPremium then
        list.TextBox.Text                              = KEY
        API.mainframe.Profile.Profile.Paid.Visible    = true
        API.mainframe.Profile.Profile.Free.Visible    = false
    else
        API.mainframe.Profile.Profile.Free.Visible    = true
        API.mainframe.Profile.Profile.Paid.Visible    = false
    end

    -- Premium key generation
    if isPremium then
        local SAVE_FOLDER = "PatchKids"
        local SAVE_FILE   = "PatchKids/%s.key"
        local Players     = game:GetService("Players")
        local player      = Players.LocalPlayer
        local username    = player.Name
        local filePath    = SAVE_FILE:format(username)

        local function ensureFolder()
            if not isfolder(SAVE_FOLDER) then makefolder(SAVE_FOLDER) end
        end

        local function loadSavedKey()
            return isfile(filePath) and readfile(filePath) or nil
        end

        local function generateKey()
            local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789abcdefghijklmnopqrstuvwxyz_"
            local hex   = ""
            for i = 1, 16 do
                hex = hex .. chars:sub(math.random(1, #chars), math.random(1, #chars))
            end
            return ("PK-%s-%s"):format(username:upper(), hex)
        end

        local function saveKey(key)
            ensureFolder()
            writefile(filePath, key)
        end

        local saved = loadSavedKey()
        if saved then
            task.wait(0.5)
            m.New("Loaded Saved Premium Key!", 2)
            KEY = saved
            list.TextBox.Text = KEY
        else
            m.New("Generating your Premium Key...", 2)
            task.wait(0.6)

            local key               = generateKey()
            local saveOk, saveErr   = pcall(saveKey, key)

            if saveOk then
                m.New("Your Premium Key has been generated.", 1)
                KEY               = key
                list.TextBox.Text = KEY
            end
        end
    end

    API.loading.loadingui.Visible = true
    tw("Welcome, " .. game.Players.LocalPlayer.DisplayName .. "!", list.welcome, 0.02)

    -- Check key button
    list.checkkey.Activated:Connect(function()
        local input = list.TextBox.Text

        if input ~= freeKey and input ~= KEY then
            m.New("This PatchKids Key is not valid!", 2)
            return
        end

        list.checkkey.Visible = false
        list.Fetch.Visible    = true

        if input == freeKey then
            setFetch("⌛", "Checking whitelist...", "White")
            task.wait(0.25)
            setFetch("ⓧ", "Unable to find user, Using free key", "Red")
            task.wait(0.5)
            setFetch("✓", "Sucessfully fetched functions.", "Green")
        else
            setFetch("⌛", "Checking whitelist...", "White")
            task.wait(0.5)
            setFetch("✓", "Fetched whitelist!", "Green")
            task.wait(0.25)
            setFetch("⌛", "Fetching Premium...", "White")
            task.wait(0.8)
            setFetch("✓", "Sucessfully fetched premium and free functions!", "Green")
        end

        task.wait(0.5)
        list.Visible = false
        game.TweenService:Create(c.Parent.loadingui.UIScale, TweenInfo.new(0.2), { Scale = 1 }):Play()
        task.wait(2)
        game.TweenService:Create(script.Parent.UIScale, TweenInfo.new(0.2), { Scale = 0 }):Play()
        wait(0.1)
        game.TweenService:Create(script.Parent.Parent.mainframe.UIScale, TweenInfo.new(0.2), { Scale = 1 }):Play()
        script.Parent.Parent.max.Visible = true
        wait(0.1)

        local content = game.Players:GetUserThumbnailAsync(
            game.Players.LocalPlayer.UserId,
            Enum.ThumbnailType.HeadShot,
            Enum.ThumbnailSize.Size420x420
        )

        API.mainframe.Profile.Profile.User.Text  = game.Players.LocalPlayer.Name
        API.mainframe.Profile.Profile.Icon.Image = content

        script.Parent:Destroy()
    end)
end)

