G2L_MODULES[G2L["5"]] = {
    Closure = function()
        local script = G2L["5"]

        local module = {
            Icons   = { Autofarm = "rbxassetid://11896729962" },
            Buttons = {}
        }

        local RunService     = game:GetService("RunService")
        local TweenService   = game:GetService("TweenService")
        local player         = game.Players.LocalPlayer
        local mouse          = player:GetMouse()

        -- ── Helpers ──────────────────────────────────────────
        function module.NewTitle(Title, tab)
            local clone      = script.Parent.Parent.NewTabs[tab].Label:Clone()
            clone.Name       = "NEWTITLE: " .. Title
            clone.Text       = Title
            clone.Parent     = script.Parent.Parent.NewTabs[tab]
            clone.Visible    = true
        end

        -- ── NewWindowV2 (with keybind support) ───────────────
        function module.NewWindowV2(Title, Desc, tab, Func)
            local clone = GeneratedTemplates.Template:Clone()
            library.AddThemesToTemplate(clone)
            clone.Name            = Title
            clone.Title.Text      = Title
            clone.Desc.Text       = Desc
            clone.Title.Size      = UDim2.fromScale(0.7, 1)
            clone.Button.Visible  = false
            clone.Parent          = script.Parent.Parent.NewTabs[tab]
            clone.Visible         = true

            if Func then
                clone.Button.Visible = true

                clone.Button.Activated:Connect(function()
                    if not CreatedButtons[Title] then
                        local newButton       = module.NewButton(Title)
                        CreatedButtons[Title] = newButton
                        newButton.Activated:Connect(Func)
                        TweenService:Create(clone.Button, TweenInfo.new(0.25), { ImageColor3 = Color3.fromRGB(186, 255, 183) }):Play()
                    else
                        TweenService:Create(clone.Button, TweenInfo.new(0.25), { ImageColor3 = Color3.fromRGB(255, 255, 255) }):Play()
                        library.RemoveDrag(Drags, "Button_" .. Title)
                        CreatedButtons[Title]:Destroy()
                        CreatedButtons[Title] = nil
                    end
                end)
            end

            -- Keybind logic
            local currentKey = nil
            local listening  = false
            clone.KeybindTitle.Text = "Set key"

            clone.Keybind.Activated:Connect(function()
                if listening then return end
                listening = true
                clone.KeybindTitle.Text = "..."

                local connection
                connection = UserInputService.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

                    if input.KeyCode == Enum.KeyCode.Escape then
                        clone.KeybindTitle.Text = "None"
                        listening = false
                        connection:Disconnect()
                        return
                    end

                    currentKey              = input.KeyCode
                    clone.KeybindTitle.Text = currentKey.Name
                    listening               = false
                    connection:Disconnect()
                end)
            end)

            clone.Execute.Activated:Connect(Func)

            UserInputService.InputBegan:Connect(function(input, gpe)
                if gpe or listening or not currentKey then return end
                if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
                if input.KeyCode == currentKey then Func() end
            end)
        end

        -- ── NewWindow (simple, no keybind) ────────────────────
        function module.NewWindow(Title, Desc, tab, buttonFunc)
            local clone = GeneratedTemplates.Template:Clone()
            library.AddThemesToTemplate(clone)
            clone.Name                   = "Title"
            clone.Title.Text             = Title
            clone.Desc.Text              = Desc
            clone.Title.Size             = UDim2.fromScale(0.7, 1)
            clone.Title.Position         = UDim2.new(0, 0, 0, 0)
            clone.Button.Position        = UDim2.fromScale(clone.Button.Position.X.Scale + 0.15, 0.5)
            clone.Keybind.Visible        = false
            clone.KeybindTitle.Visible   = false
            clone.Button.Visible         = false
            clone.Parent                 = script.Parent.Parent.NewTabs[tab]
            clone.Visible                = true

            if buttonFunc then
                clone.Button.Visible = true

                clone.Button.Activated:Connect(function()
                    if not CreatedButtons[Title] then
                        local newButton       = module.NewButton(Title)
                        CreatedButtons[Title] = newButton
                        newButton.Activated:Connect(buttonFunc)
                        TweenService:Create(clone.Button, TweenInfo.new(0.25), { ImageColor3 = Color3.fromRGB(186, 255, 183) }):Play()
                    else
                        TweenService:Create(clone.Button, TweenInfo.new(0.25), { ImageColor3 = Color3.fromRGB(255, 255, 255) }):Play()
                        library.RemoveDrag(Drags, "Button_" .. Title)
                        CreatedButtons[Title]:Destroy()
                        CreatedButtons[Title] = nil
                    end
                end)

                clone.Execute.Activated:Connect(buttonFunc)
            end

            return clone.Execute
        end

        -- ── NewToggle ─────────────────────────────────────────
        function module.NewToggle(Title, Desc, tab)
            local clone = GeneratedTemplates.TemplateToggle:Clone()
            library.AddThemesToTemplate(clone)
            clone.Name            = "Title"
            clone.Title.Text      = Title
            clone.Parent          = script.Parent.Parent.NewTabs[tab]
            clone.Visible         = true

            clone.Execute.Toggle.Changed:Connect(function()
                if clone.Execute.Toggle.Value then
                    game.TweenService:Create(clone.Execute.Frame, TweenInfo.new(0.1), { Position = clone.Execute.On.Position }):Play()
                    game.TweenService:Create(clone.Execute.Frame, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(186, 255, 183) }):Play()
                else
                    game.TweenService:Create(clone.Execute.Frame, TweenInfo.new(0.1), { Position = clone.Execute.Off.Position }):Play()
                    game.TweenService:Create(clone.Execute.Frame, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(255, 255, 255) }):Play()
                end
            end)

            return clone.Execute
        end

        -- ── NewButton ─────────────────────────────────────────
        function module.NewButton(Title)
            local new = GeneratedTemplates.MovingButton:Clone()
            library.AddThemesToTemplate(new)
            new.Name    = Title
            new.Text    = Title
            new.Parent  = script.Parent.Parent.Parent
            new.Visible = true
            library.AddDraggingTo(new, Drags, "Button_" .. Title)
            return new
        end

        -- ── NewSlider ─────────────────────────────────────────
        function module.NewSlider(Title, Min, Max, Default, Tab, Callback)
            local clone       = GeneratedTemplates.SliderTemplate:Clone()
            library.AddThemesToTemplate(clone)
            clone.Name        = Title

            local Slider      = clone:WaitForChild("Slider")
            local Moving      = Slider:WaitForChild("Moving")
            local Info        = Moving:WaitForChild("Info")
            local InfoScale   = Info:WaitForChild("UIScale")
            local TitleLabel  = clone:WaitForChild("Title")

            local INFO_HIDE_DELAY = 1.5
            local isDragging      = false
            local hideInfoThread  = nil
            local currentValue    = math.clamp(Default, Min, Max)

            TitleLabel.Text   = Title
            Info.Text         = string.format("%.2f", currentValue)
            InfoScale.Scale   = 0
            clone.Parent      = script.Parent.Parent.NewTabs[Tab]

            local defaultAlpha    = (currentValue - Min) / (Max - Min)
            Moving.Position       = UDim2.new(defaultAlpha, 0, 0.5, 0)

            local function tweenScale(target)
                TweenService:Create(InfoScale, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Scale = target }):Play()
            end

            local function showInfo()
                if hideInfoThread then task.cancel(hideInfoThread); hideInfoThread = nil end
                tweenScale(1)
            end

            local function scheduleHideInfo()
                if hideInfoThread then task.cancel(hideInfoThread) end
                hideInfoThread = task.delay(INFO_HIDE_DELAY, function()
                    tweenScale(0)
                    hideInfoThread = nil
                end)
            end

            local function updateSlider(inputX)
                local absPos  = Slider.AbsolutePosition
                local absSize = Slider.AbsoluteSize
                local relX    = math.clamp(inputX - absPos.X, 0, absSize.X)
                local alpha   = relX / absSize.X

                currentValue    = math.clamp(Min + alpha * (Max - Min), Min, Max)
                Moving.Position = UDim2.new(alpha, 0, 0.5, 0)
                Info.Text       = string.format("%.2f", currentValue)

                if Callback then Callback(currentValue) end
            end

            local function beginDrag()
                isDragging = true
                showInfo()
            end

            Moving.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    beginDrag()
                end
            end)

            Slider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    beginDrag()
                    updateSlider(UserInputService:GetMouseLocation().X)
                end
            end)

            RunService.RenderStepped:Connect(function()
                if isDragging then
                    updateSlider(UserInputService:GetMouseLocation().X)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    if isDragging then
                        isDragging = false
                        scheduleHideInfo()
                    end
                end
            end)

            clone.Visible = true

            return {
                SetValue = function(value)
                    currentValue    = math.clamp(value, Min, Max)
                    local alpha     = (currentValue - Min) / (Max - Min)
                    Moving.Position = UDim2.new(alpha, 0, 0.5, 0)
                    Info.Text       = tostring(currentValue)
                    if Callback then Callback(currentValue) end
                end,
                GetValue = function()
                    return currentValue
                end
            }
        end

        return module
    end
}

