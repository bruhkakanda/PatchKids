					currentValue = math.clamp(value, Min, Max)
					local alpha = (currentValue - Min) / (Max - Min)
					Moving.Position = UDim2.new(alpha, 0, 0.5, 0)
					Info.Text = tostring(currentValue)
					if Callback then Callback(currentValue) end
				end,
				GetValue = function()
					return currentValue
				end
			}
