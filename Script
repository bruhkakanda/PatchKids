local function startMoving(root, coinVisual, coin)
    if moveConnection then return end
    currentCoinVisual = coinVisual
    currentCoin = coin

    moveConnection = RunService.Heartbeat:Connect(function(dt)
        if not currentCoinVisual or not currentCoinVisual.Parent then
            stopMoving() return
        end

        if currentCoinVisual:FindFirstChild("MainCoin") then
            if currentCoinVisual.MainCoin.Transparency ~= 0 then
                stopMoving() return
            end
        end

        if not TOGGLE then
            stopMoving() return
        end

        -- Pull nearby coins to player
        local CoinContainers = workspace:FindFirstChild("CoinContainer", true)
        if CoinContainers then
            for _, coinAura in CoinContainers:GetChildren() do
                local cv = coinAura:FindFirstChild("CoinVisual")
                if cv and cv:FindFirstChild("MainCoin") then
                    if cv.MainCoin.Transparency == 0 then
                        if (root.Position - coinAura.Position).Magnitude < 5 then
                            coinAura.Position = root.Position
                        end
                    end
                end
            end
        end

        local currentPos = root.Position
        local targetPos = Vector3.new(currentCoin.Position.X, LOCKED_Y, currentCoin.Position.Z)
        local direction = targetPos - currentPos
        local dist = direction.Magnitude

        if dist > 0 then
            local step = math.min(SPEED * dt, dist)
            local newPos = currentPos + direction.Unit * step
            root.CFrame = CFrame.new(newPos) * CFrame.Angles(math.rad(90), 0, 0)
        end

        if dist < 0.5 then
            stopMoving()
        end
    end)
end

local function tpToLobby()
	local lobby = workspace:FindFirstChild("Lobby") or workspace:FindFirstChild("RegularLobby")
		if lobby then
			local spawns = lobby:FindFirstChild("Spawns")
			if spawns then
				local rCF = spawns:GetChildren()[math.random(1, #spawns:GetChildren())].CFrame + Vector3.new(0, 2, 0)
				game.Players.LocalPlayer.Character:PivotTo(rCF)
			end
		end
end

module.Start = function()
	local this = {}
	this.id = "CoinAutofarm"
	this.settings = module.Settings[this.id]

    mainConnection = RunService.Heartbeat:Connect(function()
        if os.clock() - lastTick < 0.2 then return end
        lastTick = os.clock()

        if TOGGLE then
            local c = Players.LocalPlayer.Character
            if not (c and c.Parent and c:FindFirstChild("Humanoid")) then return end

            local hum = c:WaitForChild("Humanoid")
            local root = c.PrimaryPart

            local coinVisual, distance = getClosestCoin(root)
            local coin = nil

            if coinVisual then
                if coinVisual.Parent then
                    if coinVisual:FindFirstChild("MainCoin") then
                        coin = coinVisual.Parent
                    end
                end
            end

            if not coinVisual or not coinVisual.Parent then
                if os.clock() - lastCoinSeen < NO_COIN_TIMEOUT then
                    return
                else
                    if canReset then
                        noclip = false
                        hum.PlatformStand = false
                        workspace.Gravity = 196.2
						if this.settings.AutoReset then
                       		hum.Health = 0
						end
						if this.settings.TPWhenDone then
                       		tpToLobby()
						end
                        canReset = false
                        stopNoclip()
                        stopMoving()
                    end
                end
            else
                canReset = true
                lastCoinSeen = os.clock()
                noclip = true
                hum.PlatformStand = true
                workspace.Gravity = 0
                startNoclip()
            end

            lastCoinSeen = os.clock()

            if coin and coin.Parent then
                if not LOCKED_Y then
                    LOCKED_Y = root.Position.Y
                end

                local targetY = coin.Position.Y - (coin.Size.Y / 2) - 2
                if math.abs(targetY - LOCKED_Y) > 0.1 then
                    LOCKED_Y = targetY
                end

				root.Anchored = false

                startMoving(root, coinVisual, coin)
            end
        else
            workspace.Gravity = 196.2
            noclip = false
            stopNoclip()
            stopMoving()
            local c = Players.LocalPlayer.Character
            if c and c:FindFirstChild("Humanoid") then
                c.Humanoid.PlatformStand = false
            end
            LOCKED_Y = nil
        end
    end)
end

return module

	end;
