function library:SetTheme(themeName)
	local theme = library.Themes[themeName]
	if theme then
		library.CurrentTheme = theme
	else
		return false
	end
end

function library:AddParticles()
	if not library.CurrentTheme.effects then return end

	local UI = library.CreatedUI
	if not UI then return end

	local MainFrame = UI:FindFirstChild("mainframe")
	if not MainFrame then return end
	if MainFrame:FindFirstChild("ThemeParticles") then return end

	local ParticleFolder = Instance.new("Folder")
	ParticleFolder.Name = "ThemeParticles"
	ParticleFolder.Parent = MainFrame

	local particles = {}
	local particleCount = 35

	local themeColors = {}
	for key, value in pairs(library.CurrentTheme) do
		if typeof(value) == "Color3" then
			table.insert(themeColors, value)
		end
	end

	if #themeColors == 0 then return end

	local function brighten(color)
		return Color3.new(
			math.clamp(color.R * 1.3, 0, 1),
			math.clamp(color.G * 1.3, 0, 1),
			math.clamp(color.B * 1.3, 0, 1)
		)
	end

	for i = 1, particleCount do
		local star = Instance.new("Frame")
		star.Size = UDim2.fromOffset(math.random(2,4), math.random(2,4))
		star.BorderSizePixel = 0
		star.AnchorPoint = Vector2.new(0,0)
		star.Parent = ParticleFolder

		local randomThemeColor = themeColors[math.random(1, #themeColors)]
		star.BackgroundColor3 = brighten(randomThemeColor)
		star.BackgroundTransparency = math.random()

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(1,0)
		corner.Parent = star

		local absSize = MainFrame.AbsoluteSize
		local startPos = Vector2.new(
			math.random(0, absSize.X),
			math.random(0, absSize.Y)
		)

		star.Position = UDim2.fromOffset(startPos.X, startPos.Y)

		particles[#particles+1] = {
			Instance = star,
			Position = startPos,
			Speed = Vector2.new(
				(math.random()-0.5) * 20,
				(math.random()-0.5) * 20
			),
			TwinkleOffset = math.random() * math.pi * 2
		}
	end

	local connection
	connection = RunService.RenderStepped:Connect(function(dt)
		if not library.CurrentTheme.effects or not MainFrame.Parent then
			connection:Disconnect()
			ParticleFolder:Destroy()
			return
		end

		local absSize = MainFrame.AbsoluteSize

		for _, particle in ipairs(particles) do
			local star = particle.Instance
			if star then
				particle.Position += particle.Speed * dt

				if particle.Position.X <= 0 or particle.Position.X >= absSize.X then
					particle.Speed = Vector2.new(-particle.Speed.X, particle.Speed.Y)
				end

				if particle.Position.Y <= 0 or particle.Position.Y >= absSize.Y then
					particle.Speed = Vector2.new(particle.Speed.X, -particle.Speed.Y)
				end

				particle.Position = Vector2.new(
					math.clamp(particle.Position.X, 0, absSize.X),
					math.clamp(particle.Position.Y, 0, absSize.Y)
				)

				star.Position = UDim2.fromOffset(
					particle.Position.X,
					particle.Position.Y
				)

				star.BackgroundTransparency =
					0.4 + math.sin(tick()*2 + particle.TwinkleOffset) * 0.25
			end
		end
	end)
end

function library:ApplyTheme(themeName)
	local theme = library.Themes[themeName]
	if not theme then
		warn("Theme not found:", themeName)
		return
	end
	if not library.CreatedUI then return end

	library.CurrentTheme = theme

	for _, item in library.CreatedUI:GetDescendants() do
		if item:HasTag("Added") then
			local property = item:GetAttribute("Property")
			if property then
				item[property] = library.CurrentTheme[item:GetAttribute("Key")]
			end
		end
	end

	library:AddParticles()
end

function library:RegisterTheme(instance, property, key)
	-- key = "MainBackground", "Accent", "Text", etc.

	instance:SetAttribute("Key", key)
	instance:SetAttribute("Property", property)

	instance:AddTag("Added")

	instance[property] = library.CurrentTheme[key]
end

function library.AddDraggingTo(frame, storeTo, id)
	assert(typeof(storeTo) == "table", "storeTo must be a table")
	assert(id ~= nil, "Drag ID is required")

	if storeTo[id] then
		library.RemoveDrag(storeTo, id)
	end

	local dragData = {
		dragging = false,
		dragInput = nil,
		dragStart = nil,
		startPos = nil,
		connections = {}
	}

	local function update(position)
		if not library.DraggingEnabled then return end
		if not dragData.dragging then return end

		local delta = position - dragData.dragStart
		frame.Position = UDim2.new(
			dragData.startPos.X.Scale,
			dragData.startPos.X.Offset + delta.X,
			dragData.startPos.Y.Scale,
			dragData.startPos.Y.Offset + delta.Y
		)
	end

	dragData.connections.began = frame.InputBegan:Connect(function(input)
		if not library.DraggingEnabled then return end

		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then

			dragData.dragging = true
			dragData.dragInput = input
			dragData.dragStart = input.Position
			dragData.startPos = frame.Position

			-- TOUCH movement
			dragData.connections.touchMove = input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.Change then
					update(input.Position)
				end
			end)
		end
	end)

	-- MOUSE movement (global)
	dragData.connections.mouseMove = UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			update(input.Position)
		end
	end)

	dragData.connections.ended = frame.InputEnded:Connect(function(input)
		if input == dragData.dragInput then
			dragData.dragging = false
			dragData.dragInput = nil

			if dragData.connections.touchMove then
				dragData.connections.touchMove:Disconnect()
				dragData.connections.touchMove = nil
			end
		end
	end)

	storeTo[id] = dragData
end

function library.AddDraggingTo2(toDrag, frame, storeTo, id)
	assert(typeof(storeTo) == "table", "storeTo must be a table")
	assert(id ~= nil, "Drag ID is required")

	if storeTo[id] then
		library.RemoveDrag(storeTo, id)
	end

	local dragData = {
		dragging = false,
		dragInput = nil,
		dragStart = nil,
		startPos = nil,
		connections = {}
	}

	local function update(position)
		if not dragData.dragging then return end

		local delta = position - dragData.dragStart
		frame.Position = UDim2.new(
			dragData.startPos.X.Scale,
			dragData.startPos.X.Offset + delta.X,
			dragData.startPos.Y.Scale,
			dragData.startPos.Y.Offset + delta.Y
		)
	end

	dragData.connections.began = toDrag.InputBegan:Connect(function(input)

		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then

			dragData.dragging = true
			dragData.dragInput = input
			dragData.dragStart = input.Position
			dragData.startPos = frame.Position

			if input.UserInputType == Enum.UserInputType.Touch then
				dragData.connections.touchMove = input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.Change then
						update(input.Position)
					end
				end)
			end
		end
	end)

	dragData.connections.mouseMove = UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			and dragData.dragging
			and dragData.dragInput
			and dragData.dragInput.UserInputType == Enum.UserInputType.MouseButton1 then
			update(input.Position)
		end
	end)

	dragData.connections.ended = UserInputService.InputEnded:Connect(function(input)
		if input == dragData.dragInput then
			dragData.dragging = false
			dragData.dragInput = nil

			if dragData.connections.touchMove then
				dragData.connections.touchMove:Disconnect()
				dragData.connections.touchMove = nil
			end
		end
	end)

	storeTo[id] = dragData
end

function library.RemoveDrag(storeTo, id)
	local dragData = storeTo[id]
	if not dragData then return end

	for _, connection in pairs(dragData.connections) do
		if connection and connection.Disconnect then
			connection:Disconnect()
		end
	end

	storeTo[id] = nil
end

function library.ToggleDragging()
	library.DraggingEnabled = not library.DraggingEnabled
end

