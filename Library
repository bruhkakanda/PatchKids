library.CurrentTheme = library.Themes.Default

local function themeGet(key)
	local t = library.CurrentTheme
	if t[key] then return t[key] end
	if key == "Surface" then
		local c = t.MainBackground
		return Color3.new(math.clamp(c.R + 0.06, 0, 1), math.clamp(c.G + 0.06, 0, 1), math.clamp(c.B + 0.06, 0, 1))
	end
	if key == "TextMuted" then
		local c = t.Text
		return Color3.new(c.R * 0.5, c.G * 0.5, c.B * 0.5)
	end
	return Color3.fromRGB(255, 255, 255)
end

function library:SetTheme(themeName)
	local theme = library.Themes[themeName]
	if theme then library.CurrentTheme = theme else return false end
end

function library:ApplyTheme(themeName)
	local theme = library.Themes[themeName]
	if not theme then warn("Theme not found:", themeName) return end
	if not library.CreatedUI then return end
	library.CurrentTheme = theme
	for _, item in library.CreatedUI:GetDescendants() do
		if item:HasTag("Added") then
			local property = item:GetAttribute("Property")
			local key      = item:GetAttribute("Key")
			if property and key then item[property] = themeGet(key) end
		end
	end
	library:AddParticles()
end

function library:RegisterTheme(instance, property, key)
	instance:SetAttribute("Key", key)
	instance:SetAttribute("Property", property)
	instance:AddTag("Added")
	instance[property] = themeGet(key)
end

function library:AddParticles()
	if not library.CurrentTheme.effects then return end
	local UI = library.CreatedUI
	if not UI then return end
	local MainFrame = UI:FindFirstChild("mainframe")
	if not MainFrame then return end
	if MainFrame:FindFirstChild("ThemeParticles") then return end

	local ParticleFolder = Instance.new("Folder")
	ParticleFolder.Name   = "ThemeParticles"
	ParticleFolder.Parent = MainFrame

	local particles    = {}
	local themeColors  = {}
	for _, value in pairs(library.CurrentTheme) do
		if typeof(value) == "Color3" then table.insert(themeColors, value) end
	end
	if #themeColors == 0 then return end

	local function brighten(color)
		return Color3.new(math.clamp(color.R*1.3,0,1), math.clamp(color.G*1.3,0,1), math.clamp(color.B*1.3,0,1))
	end

	for i = 1, 35 do
		local star = Instance.new("Frame")
		star.Size = UDim2.fromOffset(math.random(2,4), math.random(2,4))
		star.BorderSizePixel = 0
		star.AnchorPoint = Vector2.new(0,0)
		star.Parent = ParticleFolder
		star.BackgroundColor3 = brighten(themeColors[math.random(1,#themeColors)])
		star.BackgroundTransparency = math.random()
		local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(1,0); corner.Parent = star
		local absSize = MainFrame.AbsoluteSize
		local startPos = Vector2.new(math.random(0,absSize.X), math.random(0,absSize.Y))
		star.Position = UDim2.fromOffset(startPos.X, startPos.Y)
		particles[#particles+1] = {
			Instance = star, Position = startPos,
			Speed = Vector2.new((math.random()-0.5)*20, (math.random()-0.5)*20),
			TwinkleOffset = math.random()*math.pi*2,
		}
	end

	local connection
	connection = RunService.RenderStepped:Connect(function(dt)
		if not library.CurrentTheme.effects or not MainFrame.Parent then
			connection:Disconnect(); ParticleFolder:Destroy(); return
		end
		local absSize = MainFrame.AbsoluteSize
		for _, p in ipairs(particles) do
			local star = p.Instance
			if star then
				p.Position += p.Speed * dt
				if p.Position.X <= 0 or p.Position.X >= absSize.X then p.Speed = Vector2.new(-p.Speed.X, p.Speed.Y) end
				if p.Position.Y <= 0 or p.Position.Y >= absSize.Y then p.Speed = Vector2.new(p.Speed.X, -p.Speed.Y) end
				p.Position = Vector2.new(math.clamp(p.Position.X,0,absSize.X), math.clamp(p.Position.Y,0,absSize.Y))
				star.Position = UDim2.fromOffset(p.Position.X, p.Position.Y)
				star.BackgroundTransparency = 0.4 + math.sin(tick()*2 + p.TwinkleOffset)*0.25
			end
		end
	end)
end

