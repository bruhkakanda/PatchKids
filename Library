--  DRAG SYSTEM  (unchanged from original)
-- ─────────────────────────────────────────────
function library.AddDraggingTo(frame, storeTo, id)
	assert(typeof(storeTo)=="table","storeTo must be a table")
	assert(id~=nil,"Drag ID is required")
	if storeTo[id] then library.RemoveDrag(storeTo,id) end
	local d = {dragging=false,dragInput=nil,dragStart=nil,startPos=nil,connections={}}
	local function update(pos)
		if not library.DraggingEnabled or not d.dragging then return end
		local delta = pos - d.dragStart
		frame.Position = UDim2.new(d.startPos.X.Scale, d.startPos.X.Offset+delta.X, d.startPos.Y.Scale, d.startPos.Y.Offset+delta.Y)
	end
	d.connections.began = frame.InputBegan:Connect(function(input)
		if not library.DraggingEnabled then return end
		if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
			d.dragging=true; d.dragInput=input; d.dragStart=input.Position; d.startPos=frame.Position
			d.connections.touchMove = input.Changed:Connect(function()
				if input.UserInputState==Enum.UserInputState.Change then update(input.Position) end
			end)
		end
	end)
	d.connections.mouseMove = UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseMovement then update(input.Position) end
	end)
	d.connections.ended = frame.InputEnded:Connect(function(input)
		if input==d.dragInput then d.dragging=false; d.dragInput=nil
			if d.connections.touchMove then d.connections.touchMove:Disconnect(); d.connections.touchMove=nil end
		end
	end)
	storeTo[id] = d
end

function library.AddDraggingTo2(toDrag, frame, storeTo, id)
	assert(typeof(storeTo)=="table","storeTo must be a table")
	assert(id~=nil,"Drag ID is required")
	if storeTo[id] then library.RemoveDrag(storeTo,id) end
	local d = {dragging=false,dragInput=nil,dragStart=nil,startPos=nil,connections={}}
	local function update(pos)
		if not d.dragging then return end
		local delta = pos - d.dragStart
		frame.Position = UDim2.new(d.startPos.X.Scale, d.startPos.X.Offset+delta.X, d.startPos.Y.Scale, d.startPos.Y.Offset+delta.Y)
	end
	d.connections.began = toDrag.InputBegan:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
			d.dragging=true; d.dragInput=input; d.dragStart=input.Position; d.startPos=frame.Position
			if input.UserInputType==Enum.UserInputType.Touch then
				d.connections.touchMove = input.Changed:Connect(function()
					if input.UserInputState==Enum.UserInputState.Change then update(input.Position) end
				end)
			end
		end
	end)
	d.connections.mouseMove = UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseMovement and d.dragging and d.dragInput and d.dragInput.UserInputType==Enum.UserInputType.MouseButton1 then
			update(input.Position)
		end
	end)
	d.connections.ended = UserInputService.InputEnded:Connect(function(input)
		if input==d.dragInput then d.dragging=false; d.dragInput=nil
			if d.connections.touchMove then d.connections.touchMove:Disconnect(); d.connections.touchMove=nil end
		end
	end)
	storeTo[id] = d
end

function library.RemoveDrag(storeTo, id)
	local dragData = storeTo[id]
	if not dragData then return end
	for _, connection in pairs(dragData.connections) do
		if connection and connection.Disconnect then connection:Disconnect() end
	end
	storeTo[id] = nil
end

function library.ToggleDragging()
	library.DraggingEnabled = not library.DraggingEnabled
end

-- ─────────────────────────────────────────────
--  INTERNAL HELPERS
-- ─────────────────────────────────────────────
local function Corner(parent, radius)
	local c = Instance.new("UICorner", parent); c.CornerRadius = UDim.new(0, radius or 6); return c
end
local function Padding(parent, top, bottom, left, right)
	local p = Instance.new("UIPadding", parent)
	p.PaddingTop=UDim.new(0,top or 0); p.PaddingBottom=UDim.new(0,bottom or 0)
	p.PaddingLeft=UDim.new(0,left or 0); p.PaddingRight=UDim.new(0,right or 0)
end
local function Stroke(parent, thickness, transparency)
	local s = Instance.new("UIStroke", parent)
	s.Thickness=thickness or 1; s.Transparency=transparency or 0; return s
end

