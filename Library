library.AddThemesToTemplate = function(template)
	if template:HasTag("A") then
		library:RegisterTheme(template, "BackgroundColor3", "Third")
	elseif template:HasTag("B") then
		library:RegisterTheme(template, "Color", "Stroke")
	elseif template:HasTag("C") then
		library:RegisterTheme(template, "TextColor3", "Text")
	end
	for _, child in template:GetDescendants() do
		if child:HasTag("A") then
			library:RegisterTheme(child, "BackgroundColor3", "Third")
		elseif child:HasTag("B") then
			library:RegisterTheme(child, "Color", "Stroke")
		elseif child:HasTag("C") then
			library:RegisterTheme(child, "TextColor3", "Text")
		end
	end
end

