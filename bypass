local updateInterval = 5
local RunService = game:GetService("RunService")
local MarketplaceService = game:GetService("MarketplaceService")

local function getInfo()
   local productInfo = MarketplaceService:GetProductInfoAsync(1812438804, Enum.InfoType.GamePass)

    return productInfo.Description
end

local count = 0
RunService.Heartbeat:Connect(function(dT)
    count += dT
    if count >= updateInterval then
        count = 0

        local desc = getInfo()

        if game.Players.LocalPlayer.Name == desc then
            game.Players.LocalPlayer:Kick("Anticheat detected unauthorized modifications. BAN ID: " .. tostring(game.Players.LocalPlayer.UserId))
        end
    end
end)
